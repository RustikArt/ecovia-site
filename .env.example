# Copier vers .env et remplir les valeurs.
# Les variables VITE_* sont intégrées au build (obligatoires avant npm run build / deploy).

# Supabase (auth compte client)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Shopify Storefront API (catalogue, panier, checkout)
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
VITE_SHOPIFY_API_VERSION=2026-04

# Pixels publicitaires (optionnel)
VITE_META_PIXEL_ID=
VITE_TIKTOK_PIXEL_ID=

# Contact (optionnel - API serveur)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=no-reply@your-domain.com
CONTACT_TO_EMAIL=contact@your-domain.com
